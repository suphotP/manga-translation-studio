# Backend Environment Variables
# Copy to .env for local development

# Server Configuration
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Data directory (default: ./data)
DATA_DIR=

# Maximum upload size in MB
MAX_UPLOAD_SIZE=50

# Maximum images per upload/chapter
MAX_IMAGES_PER_UPLOAD=1000
MAX_UPLOAD_BATCH_SIZE_MB=500
MAX_IMAGES_PER_CHAPTER=1000
MAX_CHAPTER_ORIGINAL_MB=500
MIN_UPLOAD_IMAGE_WIDTH=64
MIN_UPLOAD_IMAGE_HEIGHT=64
MAX_JSON_BODY_SIZE_KB=1024

# CORS allowed origins (* for prototype, comma-separated for production)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Worker URL
WORKER_URL=http://localhost:8001
READINESS_REQUIRE_WORKER=false
READINESS_WORKER_DISABLED=false

# Transactional email
# [PROD-DOCKER] docker-compose.yml reads these from the repo-root .env.
# Keep this backend example mirrored with ../.env.example when adding mailer vars.
# Set MAILER_PROVIDER=resend with RESEND_API_KEY for production Compose.
APP_URL=https://app.example.com
MAILER_PROVIDER=null
MAILER_FROM=Comic Workspace <hello@send.example.com>
MAILER_REPLY_TO=support@example.com
RESEND_API_KEY=
RESEND_DOMAIN=send.example.com

# JWT Authentication Configuration
# [PROD-REQUIRED] Must be set to a strong random value (32+ chars) when NODE_ENV=production.
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRY=900  # 15 minutes in seconds
JWT_REFRESH_EXPIRY=604800  # 7 days in seconds
AUTH_SESSION_STORE=redis
AUTH_SESSION_REDIS_KEY_PREFIX=manga-editor:auth
# Leave blank to auto-select: file without DATABASE_URL, postgres with DATABASE_URL.
AUTH_USER_STORE=
UPLOAD_AUDIT_STORE=postgres
PROJECT_CATALOG_STORE=postgres
# Leave blank to auto-select: file without DATABASE_URL, postgres with DATABASE_URL.
USAGE_LEDGER_STORE=

# SSO OAuth providers (Google, GitHub, LINE Login)
APP_URL=http://localhost:5173
OAUTH_REDIRECT_BASE=http://localhost:3001/api/auth/sso
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=

# API hardening. These default to true when NODE_ENV=production if left blank.
# Keep false only for local prototype compatibility, and use concrete ALLOWED_ORIGINS in production.
API_AUTH_REQUIRED=false
API_MUTATION_AUTH_REQUIRED=true
API_ORIGIN_GUARD_ENABLED=true
API_CSRF_REQUIRED=false
CSRF_TOKEN_TTL_SECONDS=28800

# Wave 0 W0.1 — legacy multi-tenant backward-compat hatch.
# When true AND API_AUTH_REQUIRED=false, projects whose state has no userId
# AND no workspaceId can be accessed without authentication (original
# prototype posture). Default false. MUST stay false in production
# (apiAuthRequired=true also forces denial). Enable only for short-lived
# migrations of pre-auth projects; each access logs a warning.
ALLOW_LEGACY_ANONYMOUS_PROJECTS=false

# Password Policy
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true

# Redis shared state
REDIS_URL=redis://redis:6379
# Enable only behind a trusted reverse proxy that strips client-supplied forwarding headers.
TRUST_PROXY_HEADERS=false
RATE_LIMIT_STORE=redis
RATE_LIMIT_AUTH_LOGIN_PER_MINUTE=10
RATE_LIMIT_AUTH_REGISTER_PER_MINUTE=5
# Max sign-ups per client IP per 24h (default 30). Per-IP, so shared egress (office /
# school / CGNAT) shares the budget — raise for group-onboarding audiences, lower for
# strictly-individual ones. Turnstile is the real bot gate; this is a backstop.
REGISTER_IP_RATE_LIMIT=30
RATE_LIMIT_AUTH_REFRESH_PER_MINUTE=60
RATE_LIMIT_AUTH_SENSITIVE_PER_MINUTE=10

# Customer support ticket REST API — tight per-user+per-ip throttle. Opening a
# ticket persists a ticket + first message AND emails/notifies the requester and
# the support queue, so it is capped far below the generic API rate. Creation is
# blocked (429) past either window; replies are cheaper and get a looser cap.
SUPPORT_TICKET_CREATE_PER_MINUTE=3
SUPPORT_TICKET_CREATE_PER_HOUR=20
SUPPORT_TICKET_REPLY_PER_MINUTE=10

# ── AI support-agent cost / anti-abuse guardrails ──────────────────────────
# Owner's #1 concern: support-ticket spam must NEVER burn LLM tokens. This is the
# SINGLE CANONICAL env block read by EVERY guardrail layer — the HTTP rate limits,
# the per-ticket lifetime caps, the global $ budget, and the spam pre-checks. There
# is intentionally no separate RATE_LIMIT_TICKET_AI_* namespace: tuning the values
# below moves the rate limiter too. Layers, cheapest -> hardest:
#   Layer 0  engagement gate    — TICKET_AI_REQUIRE_VERIFIED_EMAIL
#   Layer 1  HTTP rate limits    — TICKET_AI_MSG_PER_MINUTE / _PER_HOUR / _TOKEN_UNITS_PER_MINUTE
#   Layer 2  per-ticket caps     — TICKET_AI_MAX_MESSAGES / TICKET_AI_MAX_TOKENS
#   Layer 3  global $ budget + kill-switch — TICKET_AI_MONTHLY_BUDGET_THB / AI_SUPPORT_KILL_SWITCH
#   Layer 4  spam pre-checks      — TICKET_AI_DEDUP_WINDOW_SECONDS / TICKET_AI_MIN_MESSAGE_LENGTH / TICKET_AI_DISPOSABLE_EMAIL_DOMAINS
# All limits fail CLOSED (route to a human, never spend tokens, on any doubt).
# AI_SUPPORT_KILL_SWITCH is INVERTED (set truthy to DISABLE the agent); a typo
# fails closed to disabled. Defaults shown match readTicketAiGuardrailsConfig.
# AI_SUPPORT_KILL_SWITCH=            # unset/empty = agent ON; 1/true/on = OFF (killed)
TICKET_AI_MSG_PER_MINUTE=4
TICKET_AI_MSG_PER_HOUR=30
TICKET_AI_TOKEN_UNITS_PER_MINUTE=120
TICKET_AI_MAX_MESSAGES=12
TICKET_AI_MAX_TOKENS=40000
TICKET_AI_MONTHLY_BUDGET_THB=5000
TICKET_AI_THB_PER_TOKEN=0.001
TICKET_AI_REQUIRE_VERIFIED_EMAIL=true
TICKET_AI_DEDUP_WINDOW_SECONDS=60
TICKET_AI_MIN_MESSAGE_LENGTH=2
# Comma-separated extra throwaway-email domains (merged with the built-in seed list).
TICKET_AI_DISPOSABLE_EMAIL_DOMAINS=
# Open/reply HTTP caps (spam guard, independent of the AI-reply caps above).
RATE_LIMIT_TICKET_OPEN_PER_HOUR=5
RATE_LIMIT_TICKET_REPLY_PER_MINUTE=10

# ── AI support-agent model + loop (gpt-5.5 front-line agent) ─────────────────
# The gpt-5.5 support agent runs behind the guardrails above (its admission gate is
# MANDATORY before any model call). It reuses OPENAI_API_KEY; if that is unset the
# agent is DISABLED (it gracefully hands off to a human, never crashes).
#   SUPPORT_AGENT_PROVIDER / SUPPORT_AGENT_MODEL are validated against the provider's
#   text-model allow-list AT CONFIG LOAD (default gpt-5.5) — a bad value fails fast.
#   SUPPORT_AGENT_MAX_TOKENS caps a single reply; SUPPORT_AGENT_MAX_TOOL_ROUNDS caps
#   the number of tool round-trips per run so cost is bounded (clamped to [1,10]).
SUPPORT_AGENT_PROVIDER=openai
SUPPORT_AGENT_MODEL=gpt-5.5
SUPPORT_AGENT_MAX_TOKENS=700
SUPPORT_AGENT_MAX_TOOL_ROUNDS=5

# Cloudflare Turnstile bot protection for public auth/invite forms.
# SECURE-BY-DEFAULT: ON automatically in production (NODE_ENV=production) — you do NOT
# set this to true there; just provide TURNSTILE_SECRET_KEY + TURNSTILE_ALLOWED_HOSTNAMES
# or the api refuses to boot. The `false` below is the DEV/LOCAL default only — do NOT
# copy it into a production env unless you intend to EXPLICITLY run prod with no bot gate.
# TURNSTILE_SITE_KEY is public and may be exposed to the frontend widget.
# TURNSTILE_SECRET_KEY is server-only and must be set when enabled in production.
# Left UNSET on purpose: dev/local is OFF by the code default (NODE_ENV != production),
# and leaving it unset means a copied production env stays secure-by-default (ON) instead
# of carrying an accidental opt-out. Uncomment and set =false ONLY to explicitly disable
# the bot gate in production (e.g. behind another bot defense).
# TURNSTILE_ENABLED=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_TOKEN_CACHE_KEY_PREFIX=manga-editor:turnstile
TURNSTILE_ALLOWED_HOSTNAMES=
TURNSTILE_VERIFY_TIMEOUT_MS=3000

# Workspace plan and quota defaults
WORKSPACE_PLAN_ID=free
WORKSPACE_STORAGE_INCLUDED_BYTES=2147483648
WORKSPACE_STORAGE_EXTRA_BYTES=0
WORKSPACE_STORAGE_QUOTA_ENFORCED=true
STORAGE_QUOTA_RESERVATION_STORE=redis
STORAGE_QUOTA_RESERVATION_TTL_MS=900000
USAGE_QUOTA_ENFORCED=true

# Billing provider. Default "none" keeps the prototype/internal billing store
# active without external checkout side effects.
BILLING_PROVIDER=none
# Billing store backend. Leave blank to auto-select: "postgres" when DATABASE_URL
# is set, "file" otherwise. Do NOT hardcode "postgres" here — the local template
# ships without DATABASE_URL, and forcing postgres would make PostgresBillingStore
# throw at startup before any route is served. Set BILLING_STORE=postgres only in
# environments that also define DATABASE_URL (Dodo billing requires postgres).
BILLING_STORE=
DODO_API_KEY=
DODO_WEBHOOK_SECRET=
DODO_ENV=test_mode
# JSON map: starter_monthly/yearly, pro_monthly/yearly, studio_monthly/yearly,
# studio_plus_monthly/yearly, and optional addon_byo_api.
DODO_PRODUCT_IDS={}

# ── AI provider router (W4.7) ───────────────────────────────────────────────
# Official APIs (OpenAI / OpenRouter) are the DEFAULT AI path. The legacy
# reverse-engineered Python scraper worker is dormant unless explicitly enabled.
# AI_PYTHON_ENABLED: enable the dev/admin-only Python worker. Default FALSE in
#   every environment (prod especially). Leave unset/false in production.
AI_PYTHON_ENABLED=false
# AI_DEFAULT_PROVIDER: preferred official provider — "openai" (default) or
#   "openrouter". A malformed value fails boot instead of silently misrouting.
AI_DEFAULT_PROVIDER=openai
# See docs/AI_PROVIDERS.md for the full provider abstraction + SLA path.

# OpenAI image provider
# Optional unless OPENAI_IMAGES_ENABLED=true in an environment that uses OpenAI image generation.
OPENAI_API_KEY=
OPENAI_IMAGES_ENABLED=false
# Must be a supported OpenAI image-output model id (currently: gpt-image-1).
# An unsupported value fails fast at startup instead of failing every AI image job.
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_DEFAULT_QUALITY=low
OPENAI_IMAGE_REQUEST_TIMEOUT_MS=300000
OPENAI_IMAGE_MAX_RESULT_MB=25
# Operator kill switch for image (upload/AI-output/crop) moderation. When set it
# overrides the saved config value, so an outage / staged-rollout switch works
# without mutating data/config.json. Leave unset to use the saved config default.
OPENAI_MODERATION_ENABLED=
OPENAI_MODERATION_MODEL=omni-moderation-latest
OPENAI_MODERATION_RULESET_VERSION=1.0
# Optional JSON map, for example {"text":{"sexual/minors":0.2},"image":{"sexual":0.7}}
OPENAI_MODERATION_THRESHOLDS_JSON=
# Default is false in production and true in development/test.
OPENAI_MODERATION_FAIL_OPEN=

# Billing provider
# Optional. When BILLING_PROVIDER=dodo in production, DODO_API_KEY is [PROD-REQUIRED].
BILLING_PROVIDER=
DODO_API_KEY=

# Mail provider
# Optional. When MAILER_PROVIDER=resend in production, RESEND_API_KEY is [PROD-REQUIRED].
MAILER_PROVIDER=
RESEND_API_KEY=

# Studio BYO API add-on
# BYO_MASTER_KEY is required when customers store workspace OpenAI/OpenRouter keys.
# Use a long random string, or base64:<32 raw bytes base64>. Keys are envelope-encrypted at rest.
BYO_MASTER_KEY=
BYO_ADDON_PRICE_USD=149
BYO_API_STORE=

# Cloudflare R2 / S3-compatible object storage
STORAGE_DRIVER=local
# [PROD-REQUIRED when STORAGE_DRIVER=r2] Either R2_ENDPOINT or R2_ACCOUNT_ID, plus bucket and credentials.
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Keep blank unless a future direct-object delivery mode is deliberately added;
# user-facing delivery should stay behind signed /api/images proxy URLs for auth, egress, and audit.
R2_PUBLIC_BASE_URL=
# Defaults to false until frontend/API clients request signed URLs; malformed values fail closed.
ASSET_SIGNED_URLS_ENFORCED=
# CDN origin that proxies the backend /api/images routes, for example https://cdn.example.com.
ASSET_CDN_PROXY_BASE_URL=
ASSET_EGRESS_STORE=memory
ASSET_EGRESS_REDIS_KEY_PREFIX=manga-editor:asset-egress
ASSET_EGRESS_WINDOW_MS=3600000
ASSET_EGRESS_PROJECT_WINDOW_BYTES=0
# Malformed values fail closed instead of silently disabling the limit.
ASSET_EGRESS_LIMIT_ENFORCED=false

# Readiness checks
READINESS_REQUIRE_OBJECT_STORAGE=false
READINESS_OBJECT_STORAGE_DISABLED=false
READINESS_OBJECT_STORAGE_TIMEOUT_MS=1000

# Observability (optional)
# Sentry Error Tracking
SENTRY_DSN=https://your-sentry-dsn
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# For release tracking in Sentry
GIT_SHA=local

# CSP violation collector (optional). When set, the Content-Security-Policy
# response header will include a report-uri directive pointing at this URL.
CSP_REPORT_URI=

# Prometheus /metrics scrape protection. Both must be set in production — if
# either is missing in production the /metrics route fails closed with 503 so
# the scrape surface is never silently exposed. In development the route stays
# reachable (with a one-shot warning) so local scrapers keep working.
METRICS_BASIC_AUTH_USER=
METRICS_BASIC_AUTH_PASS=

# ── Cron scheduler (Wave 2 W2.4) ────────────────────────────────────
# Standalone cron-worker process (bun run cron:worker). Defaults to true in
# production so the cron-worker container runs jobs, false elsewhere so local
# dev does not double-run scheduled work against a shared database. Each job
# guards itself with a pg advisory lock so multiple replicas are still safe.
SCHEDULER_ENABLED=
# Internal poll interval (ms). Lower values let force-trigger and `enabled`
# flips take effect sooner; higher values reduce DB load.
SCHEDULER_POLL_INTERVAL_MS=60000
# Retention window for the audit-retention-prune job (days).
AUDIT_RETENTION_DAYS=90
# TTL for draft export jobs swept by the draft-export-cleanup job (hours).
DRAFT_EXPORT_TTL_HOURS=24
# How old (days) an unsettled AI credit reservation must be before
# monthly-credit-reset treats it as abandoned and releases it. Larger values
# are safer (never release a still-running cross-month job); the job only runs
# real work when USAGE_LEDGER_STORE=postgres (reservations live in usage_events).
AI_RESERVATION_ABANDON_AFTER_DAYS=7
# How old (days) an abandoned, never-verified LOCAL sign-up must be before the
# unverified-account-cleanup job hard-deletes it. Forward this to the scheduler's
# process (cron-worker / scheduler-enabled service) or the override silently no-ops.
UNVERIFIED_ACCOUNT_MAX_AGE_DAYS=3
