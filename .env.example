# Prototype local stack defaults. Copy to .env only for local use.
# Do not commit real secrets.

NODE_ENV=development
JWT_SECRET=replace-with-at-least-32-random-characters
ALLOWED_ORIGINS=http://localhost:5173

# Backend / worker
PORT=3001
WORKER_URL=http://worker:8001
DATA_DIR=/app/data

# Transactional email passed into the backend container by docker-compose.yml.
# Keep MAILER_PROVIDER=null for local dev; set resend with RESEND_API_KEY for production Compose.
APP_URL=https://app.example.com
MAILER_PROVIDER=null
MAILER_FROM=Comic Workspace <hello@send.example.com>
MAILER_REPLY_TO=support@example.com
RESEND_API_KEY=
RESEND_DOMAIN=send.example.com

# Frontend dev proxy inside Docker Compose
VITE_DEV_PROXY_TARGET=http://backend:3001

# Future production storage target. Prototype keeps STORAGE_DRIVER=local.
STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT=/app/data
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
ASSET_SIGNED_URLS_ENFORCED=false
ASSET_CDN_PROXY_BASE_URL=
STORAGE_QUOTA_RESERVATION_STORE=redis
STORAGE_QUOTA_RESERVATION_TTL_MS=900000

# Future durable services
POSTGRES_DB=manga_editor
POSTGRES_USER=manga
POSTGRES_PASSWORD=manga_dev_password
# Production-shaped local Postgres baseline. Tune per host before real prod.
POSTGRES_MAX_CONNECTIONS=100
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=768MB
POSTGRES_WORK_MEM=8MB
POSTGRES_MAINTENANCE_WORK_MEM=128MB
POSTGRES_CHECKPOINT_TIMEOUT=10min
POSTGRES_MAX_WAL_SIZE=1GB
POSTGRES_MIN_WAL_SIZE=128MB
POSTGRES_WAL_COMPRESSION=on
POSTGRES_IDLE_IN_TRANSACTION_SESSION_TIMEOUT=60000
POSTGRES_LOG_MIN_DURATION_STATEMENT=1000
POSTGRES_TRACK_IO_TIMING=on
POSTGRES_SHM_SIZE=1gb
POSTGRES_STOP_GRACE_PERIOD=60s
REDIS_URL=redis://redis:6379
AUTH_USER_STORE=
PROJECT_CATALOG_FILE_FALLBACK_ENABLED=
AI_QUEUE_STORE=redis
AI_QUEUE_PROCESSOR_ENABLED=true
AI_QUEUE_PROCESSOR_POLL_INTERVAL_MS=1000
AI_REQUIRE_ASSET_REGISTRY_FOR_AI=
# AI provider router (W4.7): official APIs are the default; the Python scraper
# worker is dormant unless AI_PYTHON_ENABLED=true. See docs/AI_PROVIDERS.md.
AI_PYTHON_ENABLED=false
AI_DEFAULT_PROVIDER=openai

# Local object-storage-compatible service for dev shape, not production R2.
MINIO_ROOT_USER=manga
MINIO_ROOT_PASSWORD=manga_dev_password
MINIO_BUCKET=manga-assets
