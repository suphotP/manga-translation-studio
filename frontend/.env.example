# Frontend Environment Variables
# Copy to .env.local for local development

# Backend API base URL (default: /api, proxied via Vite in dev)
VITE_API_BASE=/api

# เวลาใช้จาก MacBook/อุปกรณ์อื่นในวงแลน LAN:
# ให้ใส่ IP ของเครื่อง Windows ที่รัน backend (port 3001)
# VITE_API_BASE=http://192.168.1.X:3001
